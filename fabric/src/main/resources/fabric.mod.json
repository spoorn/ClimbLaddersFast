  "mixins": [
    "climbladdersfast-common.mixins.json"
  ],
  "accessWidener": "climbladdersfast.accesswidener",
  "depends": {
    "fabricloader": ">=0.19.3",
    "fabric-api": ">=0.152.2+26.2",
    "minecraft": ">=26.2 <26.3",
    "cloth-config2": ">=26.2.155",
    "java": ">=25"
  },
  "suggests": {
    "modmenu": ">=20.0.0-alpha.1"

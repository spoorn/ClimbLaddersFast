{
  "schemaVersion": 1,
  "id": "climbladdersfast",
  "version": "${version}",
  "name": "ClimbLaddersFast",
  "description": "Climb ladders, vines, and scaffolding faster",
  "authors": [
    "spoorn"
  ],
  "contact": {
    "homepage": "https://www.curseforge.com/minecraft/mc-mods/climb-ladders-fast",
    "sources": "https://github.com/spoorn/ClimbLaddersFast"
  },
  "license": "MIT",
  "icon": "assets/climbladdersfast/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "org.spoorn.climbladdersfast.fabric.client.ClimbLaddersFastClientFabric"
    ],
    "main": [
